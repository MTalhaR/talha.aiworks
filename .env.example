# ─────────────────────────────────────────────────────────────────
# Email notifications via Resend  →  https://resend.com  (free tier)
# ─────────────────────────────────────────────────────────────────

# 1. Create a free account at resend.com
# 2. Generate an API key in the dashboard
# 3. Copy it here
RESEND_API_KEY=

# Email address where contact form submissions will be delivered
CONTACT_EMAIL=

# "From" address shown in the notification email.
# On the free plan you can use "onboarding@resend.dev" for testing.
# For production, verify your domain and use noreply@yourdomain.com
FROM_EMAIL=onboarding@resend.dev
